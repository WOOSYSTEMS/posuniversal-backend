# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (for tiered fees)
# Get this from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Platform Stripe Account ID (optional, for collecting Interac surcharge)
# Your main Stripe account ID if using Connect
STRIPE_PLATFORM_ACCOUNT=acct_xxxxxxxxxxxxxxxxxxxx

# Server port (default: 4242)
PORT=4242
